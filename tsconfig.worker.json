{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["worker/**/*.ts", "src/engine/**/*.ts", "src/types/**/*.ts", "src/multiplayer/**/*.ts", "src/data/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
